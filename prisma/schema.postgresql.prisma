// =====================================================================
// PRISMA SCHEMA: dbakademik — PostgreSQL (Supabase / Vercel)
// Identik dengan schema.prisma (MySQL) kecuali:
//   - provider: postgresql
//   - @db.UnsignedTinyInt  → @db.SmallInt
//   - @db.Time(0)          → @db.Time
// Output ke direktori yang sama supaya seluruh kode service tidak perlu
// diubah. Jalankan `bun run prisma:generate:pg` sebelum dev:supabase.
// =====================================================================

generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  // directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------

enum JenisKelamin {
  L
  P
}

enum StatusMahasiswa {
  aktif
  lulus
}

enum Hari {
  Senin
  Selasa
  Rabu
  Kamis
  Jumat
  Sabtu
}

enum Semester {
  Ganjil
  Genap
}

enum Role {
  admin
  dosen
  mahasiswa
}

enum StatusVerifikasiIjazah {
  belum_upload
  menunggu
  diterima
  ditolak
}

// ---------------------------------------------------------------------
// FAKULTAS
// kode_fakultas: 1 digit, dipakai sebagai bagian pembentuk NIM & kode_prodi
// ---------------------------------------------------------------------
model Fakultas {
  kodeFakultas String   @id @map("kode_fakultas") @db.Char(1)
  namaFakultas String   @map("nama_fakultas") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")

  prodi Prodi[]

  @@map("fakultas")
}

// ---------------------------------------------------------------------
// PRODI
// kode_prodi (2 digit) = kode_fakultas + urutan prodi dalam fakultas itu.
// Contoh: Fakultas Teknik (kode '4'), Teknik Informatika prodi ke-1
// di fakultas itu -> kode_prodi '41'.
// ---------------------------------------------------------------------
model Prodi {
  kodeProdi    String   @id @map("kode_prodi") @db.Char(2)
  namaProdi    String   @map("nama_prodi") @db.VarChar(100)
  kodeFakultas String   @map("kode_fakultas") @db.Char(1)
  createdAt    DateTime @default(now()) @map("created_at")

  fakultas  Fakultas    @relation(fields: [kodeFakultas], references: [kodeFakultas])
  dosen     Dosen[]
  mahasiswa Mahasiswa[]

  @@index([kodeFakultas], map: "idx_prodi_fakultas")
  @@map("prodi")
}

// ---------------------------------------------------------------------
// DOSEN
// editPermission: flag yang di-set admin supaya dosen bisa update
// data dirinya (namaDosen, tglLahir, jenisKelamin). Setelah dosen
// menyimpan perubahan, flag ini otomatis di-reset ke false.
// ---------------------------------------------------------------------
model Dosen {
  kodedsn        String       @id @db.VarChar(10)
  namaDosen      String       @map("nama_dosen") @db.VarChar(100)
  tglLahir       DateTime     @map("tgl_lahir") @db.Date
  kodeProdi      String       @map("kode_prodi") @db.Char(2)
  statusAktif    Boolean      @default(true) @map("status_aktif")
  foto           String?      @db.VarChar(255)
  jenisKelamin   JenisKelamin @map("jenis_kelamin")
  editPermission Boolean      @default(false) @map("edit_permission")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  prodi Prodi @relation(fields: [kodeProdi], references: [kodeProdi])

  mahasiswaWali Mahasiswa[] @relation("DosenWali")
  jamKelas      JamKelas[]
  user          User?

  @@index([kodeProdi], map: "idx_dosen_prodi")
  @@map("dosen")
}

// ---------------------------------------------------------------------
// MAHASISWA
// ---------------------------------------------------------------------
model Mahasiswa {
  nim               String                 @id @db.VarChar(8)
  nama              String                 @db.VarChar(100)
  tglLahir          DateTime               @map("tgl_lahir") @db.Date
  jenisKelamin      JenisKelamin           @map("jenis_kelamin")
  statusMhs         StatusMahasiswa        @default(aktif) @map("status_mhs")
  ijazah            String?                @db.VarChar(255)
  ijazahStatus      StatusVerifikasiIjazah @default(belum_upload) @map("ijazah_status")
  ijazahCatatan     String?                @map("ijazah_catatan") @db.VarChar(500)
  ijazahDihapusPada DateTime?              @map("ijazah_dihapus_pada")
  foto              String?                @db.VarChar(255)
  kodeProdi         String                 @map("kode_prodi") @db.Char(2)
  angkatan          Int                    @db.SmallInt
  kodedsnWali       String?                @map("kodedsn_wali") @db.VarChar(10)
  editPermission    Boolean                @default(false) @map("edit_permission")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  prodi     Prodi  @relation(fields: [kodeProdi], references: [kodeProdi])
  dosenWali Dosen? @relation("DosenWali", fields: [kodedsnWali], references: [kodedsn])
  krs       Krs[]
  user      User?

  @@index([kodedsnWali], map: "idx_mhs_dosenwali")
  @@index([kodeProdi], map: "idx_mhs_prodi")
  @@index([kodeProdi, angkatan], map: "idx_mhs_prodi_angkatan")
  @@map("mahasiswa")
}

// ---------------------------------------------------------------------
// MATAKULIAH
// ---------------------------------------------------------------------
model Matakuliah {
  kodemk    String   @id @db.VarChar(10)
  namamk    String   @db.VarChar(100)
  sks       Int      @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  jamKelas JamKelas[]

  @@map("matakuliah")
}

// ---------------------------------------------------------------------
// JAM_KELAS
// ---------------------------------------------------------------------
model JamKelas {
  idJamkelas Int      @id @default(autoincrement()) @map("id_jamkelas")
  kodemk     String   @db.VarChar(10)
  kodedsn    String   @db.VarChar(10)
  namaKelas  String   @map("nama_kelas") @db.VarChar(5)
  hari       Hari
  jamMulai   DateTime @map("jam_mulai") @db.Time
  jamSelesai DateTime @map("jam_selesai") @db.Time
  ruangan    String?  @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")

  matakuliah Matakuliah @relation(fields: [kodemk], references: [kodemk], onDelete: Cascade)
  dosen      Dosen      @relation(fields: [kodedsn], references: [kodedsn])
  krs        Krs[]

  @@unique([kodemk, namaKelas], map: "uq_mk_kelas")
  @@unique([kodemk, kodedsn], map: "uq_mk_dosen")
  @@index([kodemk], map: "idx_jamkelas_mk")
  @@index([kodedsn], map: "idx_jamkelas_dosen")
  @@map("jam_kelas")
}

// ---------------------------------------------------------------------
// KRS (Kartu Rencana Studi)
// ---------------------------------------------------------------------
model Krs {
  idKrs         Int       @id @default(autoincrement()) @map("id_krs")
  nim           String    @db.VarChar(15)
  idJamkelas    Int       @map("id_jamkelas")
  tahunAkademik String    @map("tahun_akademik") @db.VarChar(9)
  semester      Semester
  nilaiAngka    Decimal?  @map("nilai_angka") @db.Decimal(5, 2)
  nilaiHuruf    String?   @map("nilai_huruf") @db.VarChar(2)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  mahasiswa Mahasiswa @relation(fields: [nim], references: [nim], onDelete: Cascade)
  jamKelas  JamKelas  @relation(fields: [idJamkelas], references: [idJamkelas])

  @@unique([nim, idJamkelas, tahunAkademik, semester], map: "uq_krs_mhs_kelas_periode")
  @@index([nim], map: "idx_krs_mhs")
  @@index([idJamkelas], map: "idx_krs_jamkelas")
  @@map("krs")
}

// ---------------------------------------------------------------------
// USERS (autentikasi & role)
// ---------------------------------------------------------------------
model User {
  idUser    Int       @id @default(autoincrement()) @map("id_user")
  username  String    @unique(map: "uq_username") @db.VarChar(50)
  password  String    @db.VarChar(255)
  role      Role
  nim       String?   @unique(map: "uq_users_nim") @db.VarChar(15)
  kodedsn   String?   @unique(map: "uq_users_kodedsn") @db.VarChar(10)
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  mahasiswa Mahasiswa? @relation(fields: [nim], references: [nim], onDelete: Cascade)
  dosen     Dosen?     @relation(fields: [kodedsn], references: [kodedsn], onDelete: Cascade)

  @@map("users")
}
