{
  "name": "dbakademik-api",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:xampp": "bun --env-file=.env.xampp run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "prisma:generate": "bunx prisma generate",
    "prisma:push": "bunx prisma db push",
    "db:seed": "bun run scripts/seed.ts dummy-data.sql",
    "db:csv": "bun run scripts/sql-to-csv.ts dummy-data.sql data-csv",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:studio": "bunx prisma studio"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "dotenv": "^17.4.2",
    "prisma": "6.19.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-mariadb": "6.19.3",
    "@prisma/client": "6.19.3",
    "@vercel/blob": "^0.27.0",
    "bcryptjs": "^3.0.3",
    "elysia": "^1.4.29",
    "mariadb": "^3.5.3"
  }
}
