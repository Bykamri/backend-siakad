# ─── TiDB Cloud Serverless (production / Vercel) ─────────────────────
# Dashboard → Connect → "Public Endpoint" → copy host, user, password.
# Format URL Prisma datasource:
#   mysql://<USER>:<PASSWORD>@<HOST>:4000/<DB_NAME>?sslaccept=strict
DATABASE_URL="mysql://YOUR_TIDB_USER:YOUR_TIDB_PASSWORD@gateway01.<region>.prod.aws.tidbcloud.com:4000/dbakademik?sslaccept=strict"

# Komponen yang dipakai oleh PrismaMariaDb adapter di src/utils/prisma.ts.
DB_HOST=gateway01.<region>.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=YOUR_TIDB_USER
DB_PASSWORD=YOUR_TIDB_PASSWORD
DB_NAME=dbakademik

# WAJIB true untuk TiDB Serverless (TLS required). Set false untuk XAMPP lokal.
DB_SSL=true

# Opsional: cap connection per invocation. Default 1 di Vercel, 5 di lokal.
# DB_CONNECTION_LIMIT=1

# ─── App ─────────────────────────────────────────────────────────────
JWT_SECRET="ganti_dengan_secret_acak_yang_panjang_dan_kuat"
DEFAULT_STAFF_PASSWORD=password123
PORT=3000

# ─── Vercel Blob (opsional, upload foto/ijazah) ──────────────────────
# Auto-injected di Vercel saat Blob store di-connect ke project.
# BLOB_READ_WRITE_TOKEN=
